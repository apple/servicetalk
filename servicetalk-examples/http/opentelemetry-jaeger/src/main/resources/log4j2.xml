<Configuration>
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <!-- Set OpenTelemetry SDK to DEBUG to see detailed export activity -->
    <Logger name="io.opentelemetry" level="DEBUG"/>
    
    <!-- Set ServiceTalk OpenTelemetry integration to DEBUG to see sender details -->
    <Logger name="io.servicetalk.opentelemetry" level="DEBUG"/>
    
    <!-- Set other ServiceTalk components to INFO -->
    <Logger name="io.servicetalk" level="INFO"/>
    
    <!-- Root logger -->
    <Root level="INFO">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
